# ArcMind v0.3.0 Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

ARCMIND_PORT=8100
ARCMIND_ENV=development

# ── Local Models ──
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen3:8b

# ── Embedding ──
EMBEDDING_MODEL=nomic-embed-text
ENABLE_VECTOR_MEMORY=true

# ── Scheduler ──
CRON_TIMEZONE=Asia/Taipei

# ── Telegram Channel (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Primary AI Provider ──
# Supports: MiniMax / OpenAI / Anthropic / Google / Groq / Mistral
CUSTOM_MODEL_BASE_URL=https://api.openai.com/v1
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=gpt-4o

# ── Alternative Providers (optional) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── GitHub Integration (optional) ──
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
CODEX_ENABLED=false

# ── MGIS (optional — legacy memory connector) ──
MGIS_URL=http://localhost:8000
MGIS_API_KEY=
MGIS_ADMIN_TOKEN=
