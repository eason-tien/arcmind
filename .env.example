# ArcMind v0.7.0 Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════
#  ArcMind Core
# ═══════════════════════════════════════════════════════════
ARCMIND_API_KEY=arcmind-dev-key    # Change this in production!
ARCMIND_PORT=8100
ARCMIND_ENV=development

# ── Local Models ──
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen3:8b

# ── Remote Ollama (LAN PC, optional) ──
OLLAMA_REMOTE_ENABLED=false
OLLAMA_REMOTE_BASE_URL=http://192.168.1.151:11434/v1
OLLAMA_REMOTE_DEFAULT_MODEL=qwen3:14b

# ── Embedding ──
EMBEDDING_MODEL=nomic-embed-text
ENABLE_VECTOR_MEMORY=true

# ── Scheduler ──
CRON_TIMEZONE=Asia/Taipei

# ═══════════════════════════════════════════════════════════
#  Channels
# ═══════════════════════════════════════════════════════════
# ── Telegram Channel ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=           # REQUIRED for security — restricts bot access

# ═══════════════════════════════════════════════════════════
#  AI Provider API Keys (fill in whichever you use)
# ═══════════════════════════════════════════════════════════
# ── Custom OpenAI-compatible Endpoint (LM Studio / vLLM / MiniMax) ──
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=custom

# ── Primary Providers ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Open-Source Hosting ──
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
HYPERBOLIC_API_KEY=

# ── Search-Enhanced ──
PERPLEXITY_API_KEY=

# ── China Providers ──
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
YI_API_KEY=
BAICHUAN_API_KEY=
STEPFUN_API_KEY=
SILICONFLOW_API_KEY=

# ── xAI ──
XAI_API_KEY=
COHERE_API_KEY=

# ═══════════════════════════════════════════════════════════
#  Integrations
# ═══════════════════════════════════════════════════════════
# ── GitHub ──
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_WEBHOOK_SECRET=
CODEX_ENABLED=false

# ── Pexels (Video Generation) ──
PEXELS_API_KEY=

# ── MGIS (optional — governance/memory backbone) ──
MGIS_URL=http://localhost:8000
MGIS_API_KEY=
MGIS_ADMIN_TOKEN=

# ── OpenClaw (optional) ──
OPENCLAW_URL=
